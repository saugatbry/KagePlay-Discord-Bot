# Your Discord Bot Token (get this from the Discord Developer Portal)
DISCORD_TOKEN=your_bot_token_here

# The ID of the channel where announcements should be posted
ANNOUNCEMENT_CHANNEL_ID=your_channel_id_here

# Optional: Role ID to ping when a new episode drops (e.g. 123456789012345678)
PING_ROLE_ID=

# The URL of your anime API endpoint that returns newly added episodes
# Defaults to local if not provided, but you should point this to your Vercel URL
API_URL=https://your-api-url.vercel.app/api/newadded
